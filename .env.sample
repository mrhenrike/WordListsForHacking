# .env.sample — Template de configuração para wfh.py
# Copie este arquivo para .env e preencha com suas credenciais reais.
#   cp .env.sample .env
#
# NUNCA versione o arquivo .env — ele está no .gitignore.
# Author: André Henrique (@mrhenrike)

# ── Git / GitHub ───────────────────────────────────────────────────────────────
GIT_REMOTE_HOST=github.com
GITHUB_TOKEN="ghp_SEU_TOKEN_AQUI"
GH_TOKEN="ghp_SEU_TOKEN_AQUI"
GIT_CREDENTIAL_USERNAME="seu_usuario_github"

# ── LinkedIn OAuth API ─────────────────────────────────────────────────────────
# Crie ou gerencie seu app em: https://www.linkedin.com/developers/apps
# Escopos necessários: r_liteprofile, r_emailaddress, w_member_social
#
# Access token: obtido via OAuth2 Authorization Code Flow ou LinkedIn Dev Portal.
# Expira em ~60 dias. Renovar em: https://www.linkedin.com/developers/apps/<app_id>/auth
LINKEDIN_CLIENT_ID="SEU_CLIENT_ID"
LINKEDIN_CLIENT_SECRET="SEU_CLIENT_SECRET"
LINKEDIN_ACCESS_TOKEN="SEU_ACCESS_TOKEN_OAUTH2"
LINKEDIN_USERNAME="seu@email.com"
# Opcional — usado apenas para refresh automático de token via senha (não recomendado em prod)
LINKEDIN_PASSWORD=""

# ── LinkedIn via RapidAPI (alternativa, não-oficial) ──────────────────────────
# Cadastre-se em: https://rapidapi.com/rockapis-rockapis-default/api/linkedin-profiles-and-company-data
# Deixe vazio para usar apenas a API oficial do LinkedIn.
LINKEDIN_RAPIDAPI_KEY=""
