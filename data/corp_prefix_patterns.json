  "intl_username_formats": {
    "description": "Username construction patterns by region/culture. No real names — format templates only.",
    "us_canada": {
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "john.smith", "note": "Most common in US/CA corporate"},
        {"fmt": "{fi}{ln}", "example": "jsmith", "note": "Very common shorthand"},
        {"fmt": "{fn}{li}", "example": "johns", "note": "First name + last initial"},
        {"fmt": "{fn}_{ln}", "example": "john_smith", "note": "Underscore separator"},
        {"fmt": "{fn}-{ln}", "example": "john-smith", "note": "Hyphen separator"},
        {"fmt": "{fn}{ln}", "example": "johnsmith", "note": "No separator"},
        {"fmt": "{ln}{fi}", "example": "smithj", "note": "Last-first reversed"},
        {"fmt": "{ln}.{fn}", "example": "smith.john", "note": "Reversed dot notation"},
        {"fmt": "{fi}{mi}{ln}", "example": "jbsmith", "note": "With middle initial"}
      ],
      "email_domains": ["company.com","corp.local","ad.company.com"]
    },
    "uk_ireland": {
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "james.wilson", "note": "Standard"},
        {"fmt": "{fi}{ln}", "example": "jwilson", "note": "Common shorthand"},
        {"fmt": "{fn}{ln}{emp_id}", "example": "jwilson01", "note": "With employee number"}
      ],
      "email_domains": ["company.co.uk","corp.local"]
    },
    "europe_dach": {
      "note": "Germany, Austria, Switzerland",
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "max.mustermann", "note": "Standard"},
        {"fmt": "{ln}.{fn}", "example": "mustermann.max", "note": "Reversed in some orgs"},
        {"fmt": "{fi}{ln}", "example": "mmustermann", "note": "Initial-lastname"},
        {"fmt": "{fn}.{ln}@{domain}.de", "example": "max.mustermann@firma.de"}
      ],
      "double_surnames": true,
      "umlaut_handling": {"ä":"ae","ö":"oe","ü":"ue","ß":"ss"}
    },
    "europe_france": {
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "jean.dupont"},
        {"fmt": "{fi}{ln}", "example": "jdupont"},
        {"fmt": "{fn}-{ln}", "example": "jean-dupont", "note": "Hyphenated double names common"}
      ],
      "accent_handling": {"é":"e","è":"e","ê":"e","ë":"e","à":"a","â":"a","ç":"c","î":"i","ï":"i","ô":"o","ù":"u","û":"u","ü":"u"}
    },
    "europe_iberia": {
      "note": "Spain, Portugal",
      "patterns": [
        {"fmt": "{fn}.{ln1}", "example": "juan.garcia", "note": "First paternal surname only"},
        {"fmt": "{fn}.{ln1}{ln2}", "example": "juan.garcialopez", "note": "Both surnames concatenated"},
        {"fmt": "{fn}.{ln1}.{ln2}", "example": "juan.garcia.lopez", "note": "Both surnames with dots"},
        {"fmt": "{fi}{ln1}", "example": "jgarcia"},
        {"fmt": "{fi}{ln1}{ln2}", "example": "jgarcialopez"}
      ],
      "double_surnames": true,
      "accent_handling": {"á":"a","é":"e","í":"i","ó":"o","ú":"u","ñ":"n","ã":"a","õ":"o","ç":"c"}
    },
    "europe_nordics": {
      "note": "Sweden, Norway, Denmark, Finland, Iceland",
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "erik.johansson"},
        {"fmt": "{fi}{ln}", "example": "ejohansson"},
        {"fmt": "{fn}{fi_ln4}", "example": "erikjoha", "note": "Truncated lastname"}
      ],
      "char_handling": {"å":"a","ä":"a","ö":"o","æ":"ae","ø":"o"}
    },
    "europe_eastern": {
      "note": "Poland, Czech, Romania, Hungary, etc.",
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "jan.kowalski"},
        {"fmt": "{fi}{ln}", "example": "jkowalski"},
        {"fmt": "{ln}{fn}", "example": "kowalskijan", "note": "Some orgs use lastname-first"}
      ],
      "char_handling": {"ą":"a","ć":"c","ę":"e","ł":"l","ń":"n","ó":"o","ś":"s","ź":"z","ż":"z","č":"c","ř":"r","š":"s","ž":"z","ő":"o","ű":"u","ă":"a","ș":"s","ț":"t"}
    },
    "latam": {
      "note": "Mexico, Colombia, Argentina, Chile, Peru, etc.",
      "patterns": [
        {"fmt": "{fn}.{ln1}", "example": "carlos.gomez"},
        {"fmt": "{fi}{ln1}", "example": "cgomez"},
        {"fmt": "{fn}.{ln1}.{ln2}", "example": "carlos.gomez.lopez"},
        {"fmt": "{fn}{ln1}", "example": "carlosgomez"},
        {"fmt": "{fi}{ln1}{ln2}", "example": "cgomezlopez"}
      ],
      "double_surnames": true,
      "accent_handling": {"á":"a","é":"e","í":"i","ó":"o","ú":"u","ñ":"n"}
    },
    "japan": {
      "patterns": [
        {"fmt": "{ln}.{fn}", "example": "tanaka.taro", "note": "Family name first (Japanese convention)"},
        {"fmt": "{fi_ln}{fn}", "example": "ttaro"},
        {"fmt": "{fn}.{ln}", "example": "taro.tanaka", "note": "Western-order used in some intl companies"},
        {"fmt": "{fn}{ln}", "example": "tarotanaka"},
        {"fmt": "{ln}{fn}", "example": "tanakataro"}
      ],
      "romanization": "hepburn",
      "note_naming": "Japanese names often romanized: ō→o or ou, ū→u or uu"
    },
    "china": {
      "patterns": [
        {"fmt": "{ln}{fn}", "example": "wangwei", "note": "Family name first, no separator"},
        {"fmt": "{fn}.{ln}", "example": "wei.wang", "note": "Western-order for intl companies"},
        {"fmt": "{fi}{ln}", "example": "wwang"},
        {"fmt": "{english_name}.{ln}", "example": "david.wang", "note": "English+Chinese surname common"}
      ],
      "romanization": "pinyin"
    },
    "korea": {
      "patterns": [
        {"fmt": "{ln}{fn}", "example": "kimminsu", "note": "Family name first"},
        {"fmt": "{fn}.{ln}", "example": "minsu.kim", "note": "Western-order"},
        {"fmt": "{fi}{ln}", "example": "mkim"},
        {"fmt": "{english_name}.{ln}", "example": "daniel.kim"}
      ],
      "romanization": "revised_romanization"
    },
    "india": {
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "raj.sharma"},
        {"fmt": "{fi}{ln}", "example": "rsharma"},
        {"fmt": "{fn}{ln}", "example": "rajsharma"},
        {"fmt": "{fn}.{mi}.{ln}", "example": "raj.k.sharma", "note": "Middle initial common"}
      ],
      "note_naming": "South Indian: may have only one name; initials expand differently"
    },
    "middle_east_north_africa": {
      "note": "Arabic naming: given + father + grandfather + family, but corporate often simplifies",
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "ahmed.hassan"},
        {"fmt": "{fi}{ln}", "example": "ahassan"},
        {"fmt": "{fn}{ln}", "example": "ahmedhassan"},
        {"fmt": "{fn}.{father_name}.{ln}", "example": "ahmed.mohammed.hassan"}
      ],
      "transliteration_variants": {"محمد":["mohammed","muhammad","mohammad","mohamad"],"أحمد":["ahmed","ahmad"],"علي":["ali"],"حسن":["hassan","hasan"]}
    },
    "russia_cis": {
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "ivan.petrov"},
        {"fmt": "{fi}{ln}", "example": "ipetrov"},
        {"fmt": "{ln}.{fi}{patronymic_i}", "example": "petrov.ia", "note": "lastname.initials (Russian corporate)"},
        {"fmt": "{fn}{patronymic_i}{ln}", "example": "iaivanov"}
      ],
      "transliteration": {"а":"a","б":"b","в":"v","г":"g","д":"d","е":"e","ё":"yo","ж":"zh","з":"z","и":"i","й":"y","к":"k","л":"l","м":"m","н":"n","о":"o","п":"p","р":"r","с":"s","т":"t","у":"u","ф":"f","х":"kh","ц":"ts","ч":"ch","ш":"sh","щ":"shch","ы":"y","э":"e","ю":"yu","я":"ya"}
    },
    "turkey": {
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "mehmet.yilmaz"},
        {"fmt": "{fi}{ln}", "example": "myilmaz"},
        {"fmt": "{fn}{ln}", "example": "mehmetyilmaz"}
      ],
      "char_handling": {"ç":"c","ğ":"g","ı":"i","İ":"I","ö":"o","ş":"s","ü":"u"}
    },
    "southeast_asia": {
      "note": "Indonesia, Philippines, Thailand, Vietnam, Malaysia, Singapore",
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "budi.santoso"},
        {"fmt": "{fi}{ln}", "example": "bsantoso"},
        {"fmt": "{fn}{ln}", "example": "budisantoso"}
      ],
      "note_naming": "Indonesian: may have single name; Vietnamese: family name first (Nguyen Van An → an.nguyen or nguyen.an); Thai: formal first+last but nicknames common"
    },
    "africa": {
      "note": "Nigeria, South Africa, Kenya, Egypt, etc.",
      "patterns": [
        {"fmt": "{fn}.{ln}", "example": "chidi.okafor"},
        {"fmt": "{fi}{ln}", "example": "cokafor"},
        {"fmt": "{fn}{ln}", "example": "chidiokafor"}
      ],
      "note_naming": "Some cultures use patronymics, clan names, or titles as part of the username"
    }
  },

  "intl_password_patterns": {
    "description": "Corporate password patterns commonly observed across regions — no company-specific data",
    "us_patterns": [
      "{Company}@{year}","{Company}#{year}","{Company}{season}{year}",
      "Welcome{year}!","P@ssw0rd{year}","Changeme{n}!","{City}{year}!",
      "{Company}1!","{Company}2024!","Summer{year}!","Winter{year}!",
      "Welcome1!","Password1!","Temp1234!","NewHire{year}!"
    ],
    "eu_patterns": [
      "{Firma}@{year}","{Société}{year}!","{Empresa}{ano}#",
