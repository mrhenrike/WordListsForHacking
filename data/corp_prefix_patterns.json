  "username_patterns": {
    "description": "Token reference: {prefix} dept/role alias, {fn} first name, {ln} last name, {fi} first initial, {li} last initial, {sep} separator",
    "patterns": [
      { "id": "prefix_sep_fn_sep_ln",    "fmt": "{prefix}{sep}{fn}{sep}{ln}",  "example": "soc.joao.silva",   "priority": 1 },
      { "id": "prefix_sep_fi_ln",        "fmt": "{prefix}{sep}{fi}{ln}",       "example": "mssp.jsilva",      "priority": 2 },
      { "id": "prefix_sep_fn",           "fmt": "{prefix}{sep}{fn}",           "example": "svc.joao",         "priority": 3 },
      { "id": "prefix_sep_ln",           "fmt": "{prefix}{sep}{ln}",           "example": "redteam.silva",    "priority": 4 },
      { "id": "prefix_fn_sep_ln",        "fmt": "{prefix}{fn}{sep}{ln}",       "example": "devops-joao-silva","priority": 5 },
      { "id": "prefix_fi_sep_ln",        "fmt": "{prefix}{fi}{sep}{ln}",       "example": "hd-j-silva",       "priority": 6 },
      { "id": "prefix_fn_ln",            "fmt": "{prefix}{fn}{ln}",            "example": "svcjoaosilva",     "priority": 7 },
      { "id": "fn_sep_ln_sep_prefix",    "fmt": "{fn}{sep}{ln}{sep}{prefix}",  "example": "joao.silva.soc",   "priority": 8 },
      { "id": "fi_ln_sep_prefix",        "fmt": "{fi}{ln}{sep}{prefix}",       "example": "jsilva.msp",       "priority": 9 },
      { "id": "prefix_sep_ini",          "fmt": "{prefix}{sep}{ini}",          "example": "devops.js",        "priority": 10 }
    ]
  },

